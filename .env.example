# Neon PostgreSQL connection strings
# Get these from your Neon dashboard → Connection Details
# DATABASE_URL = pooled connection (used at runtime by the app)
# DIRECT_URL   = direct connection (used by Prisma migrations / db push)

DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.REGION.aws.neon.tech/DBNAME?sslmode=require"
